# Database
# Local SQLite (default for dev): file:./dev.db
# Render persistent disk: file:/var/data/capixelate.db
# Turso/libSQL remote: libsql://your-db.turso.io?authToken=your-token
DATABASE_URL=file:./dev.db

# File upload storage directory
# Default (dev): public/uploads  (served as Next.js static files)
# Render (prod): /var/data/uploads  (served via /api/files/ route)
UPLOAD_DIR=

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=capixelate2024

# JWT signing secret — use a strong random string in production
NEXTAUTH_SECRET=capixelate-secret-key

# ── Split-deployment settings ──────────────────────────────────────────────────
# Set on the Render service: the URL of the Render app itself.
# Returned in upload responses so the frontend knows where to fetch files.
# Example: https://capixelate-api.onrender.com
NEXT_PUBLIC_API_BASE_URL=

# Set on the Render service: the Vercel frontend origin, for CORS.
# Use * to allow any origin (not recommended in production).
# Example: https://capixelate.vercel.app
ALLOWED_ORIGIN=*
