# Database — either a local SQLite file (dev) or a Turso/libSQL URL (prod).
# Local dev:   file:./dev.db
# Turso/prod:  libsql://your-db.turso.io
DATABASE_URL=file:./dev.db

# Only needed when DATABASE_URL points at Turso.
TURSO_AUTH_TOKEN=

# Vercel Blob — file uploads (admin panel) live here.
# Get this from the Vercel dashboard: Storage -> Blob -> Connect.
BLOB_READ_WRITE_TOKEN=

# Admin credentials for /admin.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=capixelate2024

# JWT signing secret — use a strong random string in production.
NEXTAUTH_SECRET=capixelate-secret-key
