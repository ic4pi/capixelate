generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  url         String
  imageUrl    String?
  iconUrl     String?
  tags        String   @default("[]")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  islandId    String?
  island      Island?  @relation(fields: [islandId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Island {
  id           String    @id @default(cuid())
  name         String
  posX         Float     @default(0)
  posZ         Float     @default(0)
  scale        Float     @default(1)
  modelUrl     String?
  // Per-model transform overrides — applied to the loaded GLB before adding
  // it to the scene, so a custom-uploaded model that's off-axis or wrong-scale
  // can be nudged without re-exporting from Blender.
  modelRotationY Float @default(0)
  modelYOffset   Float @default(0)
  isDiscovered Boolean   @default(false)
  isActive     Boolean   @default(true)
  projects     Project[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Enemy {
  id              String   @id @default(cuid())
  name            String
  type            String   @default("ship")
  modelUrl        String?
  modelScale      Float    @default(1)
  modelRotationY  Float    @default(0)
  modelYOffset    Float    @default(0)
  lootImageUrl    String?
  hitPoints       Int      @default(3)
  cannonAccuracy  Float    @default(0.5)
  difficulty      String   @default("normal")
  behavior        String   @default("fight")
  attackMode      String   @default("cannon")
  fleeThreshold   Float    @default(0.25)
  lootValue       Int      @default(100)
  lootDifficulty  String   @default("normal")
  zoneX           Float    @default(0)
  zoneZ           Float    @default(0)
  zoneRadius      Float    @default(200)
  speed           Float    @default(1)
  isActive        Boolean  @default(true)
  spawnCount      Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Ship {
  id             String   @id @default(cuid())
  name           String
  type           String   @default("player")
  modelUrl       String?
  modelScale     Float    @default(1)
  modelRotationY Float    @default(0)
  modelYOffset   Float    @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model GameConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
